<%= form_with(model: article) do |form| %>
  <% if article.errors.any? %>
    <%# Alerte rouge Bootstrap %>
    <div class="alert alert-danger shadow-sm">
      <h4 class="alert-heading"><%= pluralize(article.errors.count, "erreur") %> :</h4>
      <ul class="mb-0">
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, "Titre de l'article", class: "form-label fw-bold" %>
    <%= form.text_field :title, class: "form-control", placeholder: "Entrez un titre (min. 5 caractères)" %>
  </div>

  <div class="mb-3">
    <%= form.label :body, "Contenu", class: "form-label fw-bold" %> <%# Corrigé : form-label est mieux ici %>
    <%= form.text_area :body, class: "form-control", rows: 5, placeholder: "Écrivez votre texte ici..." %>
  </div>

  <div class="mb-4 p-3 bg-light border rounded shadow-sm">
    <div class="form-check form-switch">
      <%= form.check_box :private, class: "form-check-input", role: "switch" %>
      <%= form.label :private, "Rendre cet article privé ?", class: "form-check-label fw-bold" %>
      <div class="form-text text-muted">Si activé, seul vous pourrez voir cet article dans la liste.</div>
    </div>
  </div>

  <div class="mt-4 border-top pt-3">
    <%= form.submit "Enregistrer l'article", class: "btn btn-success btn-lg" %>
    <%= link_to "Annuler", articles_path, class: "btn btn-outline-secondary btn-lg ms-2" %>
  </div>
<% end %>