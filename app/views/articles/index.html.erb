<p style="color: green" class="alert alert-success"><%= notice %></p>

<% content_for :title, "Articles" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Articles</h1>
  <%= link_to "Nouvel article", new_article_path, class: "btn btn-primary" %>
</div>

<%# --- BARRE DE RECHERCHE --- %>
<div class="card bg-light mb-4 shadow-sm">
  <div class="card-body">
    <%= form_with url: articles_path, method: :get, class: "row g-2" do |form| %>
      <div class="col-md-8">
        <%= form.text_field :query, 
                            value: params[:query], 
                            placeholder: "Rechercher par titre...", 
                            class: "form-control" %>
      </div>
      <div class="col-md-4 d-flex gap-2">
        <%= form.submit "Chercher", class: "btn btn-outline-primary w-100" %>
        <% if params[:query].present? %>
          <%= link_to "Effacer", articles_path, class: "btn btn-outline-secondary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<button id="count-btn" class="btn btn-info mb-3 shadow-sm">Compter les articles</button>

<div id="articles">
  <% if @articles.any? %>
    <% @articles.each do |article| %>
      <div class="article-item border-bottom mb-3 pb-3">
        <%# --- Badge Privé à l'intérieur de la boucle --- %>
        <% if article.private %>
          <span class="badge bg-warning text-dark mb-2">🔒 Privé</span>
        <% end %>

        <%= render article %>
        
        <div class="mt-2">
          <%= link_to "Voir l'article", article, class: "btn btn-sm btn-outline-info" %>
          
          <%# Optionnel : Afficher l'auteur pour vérifier le bonus 2.6.2 %>
          <small class="text-muted ms-2">Par <%= article.user.email %></small>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="alert alert-warning">
      Aucun article ne correspond à votre recherche "<strong><%= params[:query] %></strong>".
    </div>
  <% end %>
</div>