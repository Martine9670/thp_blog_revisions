<p style="color: green"><%= notice %></p>

<% content_for :title, "Articles" %>

<h1>Articles</h1>

<button id="count-btn" class="btn btn-info mb-3">Compter les articles</button>

<div id="articles">
  <% @articles.each do |article| %>
    <div class="article-item border-bottom mb-3 pb-2"> <%= render article %>
      <%= link_to "Show this article", article %>
    </div>
  <% end %>
</div>
<%= link_to "New article", new_article_path, class: "btn btn-primary" %>