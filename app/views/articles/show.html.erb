<p style="color: green" class="alert alert-success"><%= notice %></p>

<%= render @article %>

<hr class="my-5">

<div id="comments-section">
  <h3>Commentaires</h3>
  <div id="comments" class="mb-4">
    <%# Rails comprend tout seul qu'il doit boucler sur les commentaires et utiliser le partial _comment %>
    <%= render @article.comments %>
  </div>

  <%# On appelle le partial du formulaire en lui passant l'article actuel %>
  <%= render "comments/form", article: @article %>
</div>

<div class="actions mt-4 pt-3 border-top">
  <%= link_to "Modifier cet article", edit_article_path(@article), class: "btn btn-warning" %>
  <%= link_to "Retour aux articles", articles_path, class: "btn btn-outline-secondary" %>
  
  <div class="float-end">
    <%= button_to "Supprimer l'article", @article, method: :delete, 
                  class: "btn btn-danger", 
                  data: { confirm: "Êtes-vous sûre ?" } %>
  </div>
</div>