<p style="color: green" class="alert alert-success"><%= notice %></p>

<%= render @article %>

<hr class="my-5">

<div id="comments-section">
  <h3>Commentaires</h3>
  <div id="comments" class="mb-4">
    <%# --- ON GARDE UNIQUEMENT CETTE BOUCLE AVEC LE BOUTON --- %>
    <% @article.comments.each do |comment| %>
      <% if comment.persisted? %>
        <div class="card mb-2 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <p class="mb-1"><strong><%= comment.commenter %></strong> a dit :</p>
                <p class="text-muted mb-0"><%= comment.body %></p>
              </div>
              
              <%= button_to "Supprimer", [comment.article, comment], 
                            method: :delete, 
                            class: "btn btn-outline-danger btn-sm",
                            data: { confirm: "Supprimer ce commentaire ?" } %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="card bg-light p-4 mb-5">
    <h4>Ajouter un commentaire</h4>
    <%= form_with model: [ @article, @article.comments.build ] do |form| %>
      <div class="mb-3">
        <%= form.label :commenter, "Votre nom", class: "form-label fw-bold" %>
        <%= form.text_field :commenter, class: "form-control", placeholder: "Ex: Martine" %>
      </div>
      <div class="mb-3">
        <%= form.label :body, "Votre message", class: "form-label fw-bold" %>
        <%= form.text_area :body, class: "form-control", rows: 3, placeholder: "Qu'en pensez-vous ?" %>
      </div>
      <%= form.submit "Publier le commentaire", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<div class="actions mt-4 pt-3 border-top">
  <%= link_to "Modifier cet article", edit_article_path(@article), class: "btn btn-warning" %>
  <%= link_to "Retour aux articles", articles_path, class: "btn btn-outline-secondary" %>
  
  <div class="float-end">
    <%= button_to "Supprimer l'article", @article, method: :delete, 
                  class: "btn btn-danger", 
                  data: { confirm: "Êtes-vous sûre ?" } %>
  </div>
</div>