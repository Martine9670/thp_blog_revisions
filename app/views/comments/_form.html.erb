<div class="card bg-light p-4 mb-5 shadow-sm">
  <h4 class="mb-3">Ajouter un commentaire</h4>
  
  <% if user_signed_in? %>
    <%= form_with model: [ article, article.comments.build ] do |form| %>
      <%# --- On a supprimé le champ "Votre nom", car on utilise current_user.email --- %>
      <div class="mb-3">
        <label class="form-label fw-bold text-muted">Posté en tant que : <%= current_user.email %></label>
      </div>

      <div class="mb-3">
        <%= form.label :body, "Votre message", class: "form-label fw-bold" %>
        <%= form.text_area :body, class: "form-control", rows: 3, placeholder: "Qu'en pensez-vous ?" %>
      </div>

      <%= form.submit "Publier le commentaire", class: "btn btn-primary px-4" %>
    <% end %>
  <% else %>
    <div class="text-center py-3">
      <p class="text-muted">Vous devez être connecté pour commenter.</p>
      <%= link_to "Se connecter", new_user_session_path, class: "btn btn-outline-primary btn-sm" %>
    </div>
  <% end %>
</div>